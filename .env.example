# Supabase (optional - app falls back to mock data if not provided)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PayHere (Sri Lanka) - server side
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
NEXT_PUBLIC_PAYHERE_SANDBOX=true

# Storefront
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=94760181199

# Logo (optional) — overrides the default placeholders shipped at
# /public/logo.svg and /public/logo-dark.svg.
# Set these to a path under /public to use a custom logo image.
# Examples: /logo.png, /logo.svg
NEXT_PUBLIC_LOGO_SRC=
NEXT_PUBLIC_LOGO_SRC_DARK=
