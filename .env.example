# Supabase (optional - app falls back to mock data if not provided)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PayHere (Sri Lanka) - server side
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
NEXT_PUBLIC_PAYHERE_SANDBOX=true

# Storefront
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=94770000000

# Logo (optional) — set to a path under /public to use a custom logo image,
# e.g. /logo.png or /logo.svg. If unset, the "Facez" wordmark is used.
NEXT_PUBLIC_LOGO_SRC=
